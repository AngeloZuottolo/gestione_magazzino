      WHERE id = $9
    `, [m.productName, m.brand, m.quantity, m.isNew, m.date, m.notes, m.supplier, m.assignee, req.params.id]);
    res.json({ success: true });
  } catch (err) {
    res.status(500).json({ error: "Database error" });
